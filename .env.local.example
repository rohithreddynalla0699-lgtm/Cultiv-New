# Optional: enable cross-device sync (requires the sync server to be running)
# Run: node server/sync-server.mjs
#
# On the same machine use localhost; on another device on the same network
# use your local IP (e.g. 192.168.1.42).
# Frontend uses this to call sync server endpoints like /api/internal-auth and /api/events.
VITE_SYNC_SERVER_URL=http://localhost:3747

# Server-side internal auth (used by server/sync-server.mjs)
# Add these in your terminal environment or a server-side .env loader setup.
# ADMIN_OWNER_PIN=240620
# STORE_PIN_SIDDIPET=502103
# STORE_PIN_HYDERABAD=500034
# STORE_PIN_WARANGAL=506002
