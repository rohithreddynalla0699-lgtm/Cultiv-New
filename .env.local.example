# Optional: enable cross-device sync (requires the sync server to be running)
# Run: node server/sync-server.mjs
#
# On the same machine use localhost; on another device on the same network
# use your local IP (e.g. 192.168.1.42).
# Frontend uses this to call sync server endpoints like /api/events.
VITE_SYNC_SERVER_URL=http://localhost:3747

# Optional: Supabase-backed customer menu/order integrations.
# Internal admin/store login does not use Supabase auth.
# VITE_SUPABASE_URL=https://your-project.supabase.co
# VITE_SUPABASE_ANON_KEY=your-anon-key

# Optional: customer online checkout flags for local/staging only.
# Frontend checkout stays disabled unless this is explicitly true.
# VITE_CUSTOMER_ONLINE_CHECKOUT_ENABLED=true
#
# Frontend provider selection for local/staging checkout tests.
# Allowed values: mock, razorpay
# VITE_PAYMENT_PROVIDER=mock
#
# Mock checkout result for local/staging UI tests.
# Allowed values: succeeded, failed, cancelled
# VITE_MOCK_PAYMENT_OUTCOME=succeeded

# Optional: local-only QA script overrides for PIN-based internal access.
# Use non-production values that match your local seeded internal users.
# ADMIN_OWNER_PIN=your-local-test-owner-pin
# STORE_PIN_SIDDIPET=your-local-test-store-pin
# STORE_PIN_HYDERABAD=your-local-test-store-pin
# STORE_PIN_WARANGAL=your-local-test-store-pin
