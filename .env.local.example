# Optional: enable cross-device sync (requires the sync server to be running)
# Run: node server/sync-server.mjs
#
# On the same machine use localhost; on another device on the same network
# use your local IP (e.g. 192.168.1.42).
# Frontend uses this to call sync server endpoints like /api/events.
VITE_SYNC_SERVER_URL=http://localhost:3747

# Optional: Supabase-backed customer menu/order integrations.
# Internal admin/store login does not use Supabase auth.
# VITE_SUPABASE_URL=https://your-project.supabase.co
# VITE_SUPABASE_ANON_KEY=your-anon-key

# Optional: QA script overrides for PIN-based internal access.
# ADMIN_OWNER_PIN=240620
# STORE_PIN_SIDDIPET=111111
# STORE_PIN_HYDERABAD=222222
# STORE_PIN_WARANGAL=333333
