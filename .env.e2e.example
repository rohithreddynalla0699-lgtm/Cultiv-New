# Base app URL for the local or preview environment under test.
E2E_BASE_URL=http://127.0.0.1:4173

# Customer account used for login / protected route / checkout tests.
E2E_CUSTOMER_EMAIL=customer@example.com
E2E_CUSTOMER_PASSWORD=replace-with-test-password

# Internal access credentials.
E2E_OWNER_PIN=0000
E2E_ADMIN_PIN=0000

# Store/POS credentials.
E2E_STORE_NAME=Siddipet Central
E2E_STORE_PIN=0000
E2E_STORE_EMPLOYEE_NAME=QA Employee
E2E_STORE_EMPLOYEE_PIN=0000

# Safe optional mutation controls.
E2E_ENABLE_MUTATION_TESTS=false
E2E_INVENTORY_ITEM_QUERY=QA inventory item
E2E_RECEIPT_ORDER_ID=

# Optional local signup/OTP test path.
E2E_SIGNUP_FULL_NAME=
E2E_SIGNUP_PHONE=
E2E_SIGNUP_EMAIL=
E2E_SIGNUP_PASSWORD=
E2E_SIGNUP_OTP=
